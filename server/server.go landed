package server

import (
	"fmt"
	"github.com/thatrajaryan/web-server/common"
)

type ServerBlock struct {
	ServiceName   string
	ImageName     string
	RepositoryURL string
	Tag           string
	Port          int
	Replicas      int
	EnvVars       string
}

func (b *ServerBlock) Create(config map[string]interface{}) error {
	fmt.Println("[Server] Initializing Logic Server instance...")
	return b.Update(config)
}

func (b *ServerBlock) Connect(target common.Block) error {
	fmt.Printf("[Server] %s connected to downstream block\n", b.ServiceName)
	return nil
}

func (b *ServerBlock) Update(config map[string]interface{}) error {
	if val, ok := config["service_name"].(string); ok {
		b.ServiceName = val
	}
	if val, ok := config["image_name"].(string); ok {
		b.ImageName = val
	}
	if val, ok := config["repository_url"].(string); ok {
		b.RepositoryURL = val
	}
	if val, ok := config["tag"].(string); ok {
		b.Tag = val
	}
	if val, ok := config["port"].(float64); ok {
		b.Port = int(val)
	}
	if val, ok := config["replicas"].(float64); ok {
		b.Replicas = int(val)
	}
	if val, ok := config["env_vars"].(string); ok {
		b.EnvVars = val
	}

	fmt.Printf("[Server] Logic Server Configured: %s (%s:%s) with %d replicas\n",
		b.ServiceName, b.ImageName, b.Tag, b.Replicas)
	return nil
}

func (b *ServerBlock) Delete() error {
	fmt.Printf("[Server] Logic Server %s decommissioned\n", b.ServiceName)
	return nil
}
